# 服务配置
PORT=3001
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# SQLite 配置
DB_PATH=./data/korrection.db

# 阿里云短信服务
ALI_ACCESS_KEY_ID=your-access-key-id
ALI_ACCESS_KEY_SECRET=your-access-key-secret
ALI_SMS_SIGN_NAME=your-sms-sign-name
ALI_SMS_TEMPLATE_CODE=your-template-code

# 阿里云 OSS
ALI_OSS_REGION=oss-cn-hangzhou
ALI_OSS_BUCKET=your-bucket-name
ALI_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALI_OSS_ROLE_ARN=acs:ram::your-account-id:role/your-oss-role

# 阿里云百炼 (AI)
ALI_BAILIAN_API_KEY=your-bailian-api-key
ALI_BAILIAN_OCR_MODEL=qwen-vl-plus
ALI_BAILIAN_CHAT_MODEL=qwen-plus
